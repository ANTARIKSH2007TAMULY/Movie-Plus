# Recommended for production deployments (keeps secrets off client):
# VITE_TMDB_PROXY_URL=https://your-backend-or-serverless-proxy.example.com/tmdb

# Fallbacks for local dev only (these values are visible in browser bundles):
# VITE_TMDB_READ_ACCESS_TOKEN=YOUR_TMDB_READ_ACCESS_TOKEN
VITE_TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

